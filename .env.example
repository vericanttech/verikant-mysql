# Copy to `.env`. Never commit real secrets.

SECRET_KEY=change-me

# Public base URL for vitrine links and QR codes on invoices (no trailing slash).
# Local: PUBLIC_BASE_URL=http://127.0.0.1:5000
# Production: PUBLIC_BASE_URL=https://your-domain.com
# PUBLIC_BASE_URL=

# --- Option A (recommended for PythonAnywhere MySQL): build URL from plain fields ---
# Avoids putting the MySQL password inside a URI (fewer 1045 / dotenv / encoding bugs).
# PA_MYSQL_BUILD_URL=1
# PA_MYSQL_USER=vericant
# PA_MYSQL_HOST=vericant.mysql.pythonanywhere-services.com
# PA_MYSQL_PORT=3306
# PA_MYSQL_PASSWORD=your_mysql_password_from_databases_tab
# Quote database name so $ is not treated as variable expansion:
# PA_MYSQL_DATABASE="vericant$shop"

# --- Option B: single URI (DB name vericant$shop → vericant%24shop in path) ---
# SQLALCHEMY_DATABASE_URI=mysql+pymysql://vericant:YOUR_MYSQL_PASSWORD@vericant.mysql.pythonanywhere-services.com:3306/vericant%24shop?charset=utf8mb4

# --- Local dev: SSH tunnel (PA_SSH_PASSWORD = website login, not MySQL) ---
# SSH_TUNNEL=1
# PA_SSH_USER=your_pa_username
# PA_SSH_HOST=ssh.pythonanywhere.com
# PA_SSH_PASSWORD=your_pythonanywhere_website_password

# On PythonAnywhere production: leave SSH_TUNNEL unset or 0. Use Option A or B with PA’s env / WSGI.

# --- Optional: programmatic web app reload (local machine or CI; never commit token) ---
# PA_API_TOKEN=from Account → API token on pythonanywhere.com
# PA_DEPLOY_USERNAME=yourusername
# PA_WEBAPP_DOMAIN=yourusername.pythonanywhere.com
# PA_API_HOST=www.pythonanywhere.com
#   EU: PA_API_HOST=eu.pythonanywhere.com
# Then: python scripts/pa_reload_webapp.py
# Full API (create webapp, upload files, static maps): https://help.pythonanywhere.com/pages/API/

# --- Optional: scripts/pa_upload_static_files.py (upload local app/static/uploads to PA) ---
# PA_UPLOAD_REMOTE_PREFIX=/home/vericant/verikant-mysql/app/static/uploads
# PA_UPLOAD_SOURCE=app/static/uploads
# PA_UPLOAD_DELAY=1.6

# --- Optional: inventory “Retirer le fond (IA)” via Replicate rembg ---
# https://replicate.com/account/api-tokens
# REPLICATE_API_TOKEN=
# Optional: full model ref (default is pinned cjwbw/rembg)
# REPLICATE_REMBG_MODEL=cjwbw/rembg:fb8af171cfa1616ddcf1242c093f9c46bcada5ad4cf6f2fbe8b81b330ec5c003
